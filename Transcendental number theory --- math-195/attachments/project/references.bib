@article{frieze-1985,
title = {On the value of a random minimum spanning tree problem},
journal = {Discrete Applied Mathematics},
volume = {10},
number = {1},
pages = {47-56},
year = {1985},
issn = {0166-218X},
doi = {https://doi.org/10.1016/0166-218X(85)90058-7},
url = {https://www.sciencedirect.com/science/article/pii/0166218X85900587},
author = {A.M. Frieze},
abstract = {Suppose we are given a complete graph on n vertices in which the lenghts of the edges are independent identically distributed non-negative random variables. Suppose that their common distribution function F is differentiable at zero and D = F′ (0) > 0 and each edge length has a finite mean and variance. Let Ln be the random variable whose value is the length of the minimum spanning tree in such a graph. Then we will prove the following: limn → ∞E(Ln) = ζ(3)/D where ζ(3) = Σk = 1∞ 1/k3 = 1.202… and for any ε > 0 limn → ∞ Pr(|Ln− ζ(3)/D|) > ε) = 0.}
}

